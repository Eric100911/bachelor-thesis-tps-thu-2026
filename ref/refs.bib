@article{ATLASFourJets7TeV2016,
  title = {Study of Hard Double-Parton Scattering in Four-Jet Events in {$pp$} Collisions at {$\sqrt{s}=7~\text{TeV}$} with the {{ATLAS}} Experiment},
  author = {ATLAS Collaboration},
  year = 2016,
  month = nov,
  journal = {Journal of High Energy Physics},
  volume = {2016},
  number = {11},
  eprint = {1608.01857},
  primaryclass = {hep-ex},
  pages = {110},
  issn = {1029-8479},
  doi = {10.1007/JHEP11(2016)110},
  urldate = {2026-01-13},
  abstract = {Inclusive four-jet events produced in proton-proton collisions at a centre-of-mass energy of \$\textbackslash sqrt\textbraceleft s\textbraceright{} = 7\$ TeV are analysed for the presence of hard double-parton scattering using data corresponding to an integrated luminosity of 37.3 pb\$\textasciicircum\textbraceleft -1\textbraceright\$, collected with the ATLAS detector at the LHC. The contribution of hard double-parton scattering to the production of four-jet events is extracted using an artificial neural network, assuming that hard double-parton scattering can be approximated by an uncorrelated overlaying of dijet events. For events containing at least four jets with transverse momentum \$p\_\textbraceleft\textbackslash mathrm\textbraceleft T\textbraceright\textbraceright{} \textbackslash geq 20\$ GeV and pseudorapidity \${$\eta\backslash$}leq 4.4\$, and at least one having \$p\_\textbraceleft\textbackslash mathrm\textbraceleft T\textbraceright\textbraceright{} \textbackslash geq 42.5\$ GeV, the contribution of hard double-parton scattering is estimated to be \$f\_\textbraceleft\textbackslash mathrm\textbraceleft DPS\textbraceright\textbraceright{} = 0.092 \textasciicircum\textbraceleft +0.005\textbraceright\_\textbraceleft -0.011\textbraceright{} (\textbackslash mathrm\textbraceleft stat.\textbraceright ) \textasciicircum\textbraceleft +0.033\textbraceright\_\textbraceleft -0.037\textbraceright{} (\textbackslash mathrm\textbraceleft syst.\textbraceright )\$. After combining this measurement with those of the inclusive dijet and four-jet cross-sections in the appropriate phase space regions, the effective overlap area between the interacting protons, \${$\sigma\_$}\textbraceleft\textbackslash mathrm\textbraceleft eff\textbraceright\textbraceright\$, was determined to be \${$\sigma\_$}\textbraceleft\textbackslash mathrm\textbraceleft eff\textbraceright\textbraceright{} = 14.9 \textasciicircum\textbraceleft +1.2\textbraceright\_\textbraceleft -1.0\textbraceright{} (\textbackslash mathrm\textbraceleft stat.\textbraceright ) \textasciicircum\textbraceleft +5.1\textbraceright\_\textbraceleft -3.8\textbraceright{} (\textbackslash mathrm\textbraceleft syst.\textbraceright )\$ mb. This result is consistent within the quoted uncertainties with previous measurements of \${$\sigma\_$}\textbraceleft\textbackslash mathrm\textbraceleft eff\textbraceright\textbraceright\$, performed at centre-of-mass energies between 63 GeV and 8 TeV using various final states, and it corresponds to \$21\textasciicircum\textbraceleft +7\textbraceright\_\textbraceleft -6\textbraceright\$\% of the total inelastic cross-section measured at \$\textbackslash sqrt\textbraceleft s\textbraceright{} = 7\$ TeV. The distributions of the observables sensitive to the contribution of hard double-parton scattering, corrected for detector effects, are also provided.},
  archiveprefix = {arXiv},
  langid = {english},
  keywords = {High Energy Physics - Experiment},
  file = {/Users/ericwang/Zotero/storage/ACNQB5E9/Collaboration - 2016 - Study of hard double-parton scattering in four-jet events in $pp$ collisions at $sqrt s = 7$ TeV w.pdf}
}

@article{ATLASPromptJpsiJpsi8TeV2017,
  title = {Measurement of the Prompt {$J/\psi$}-pair Production Cross-Section in {$pp$} Collisions at {$\sqrt{s}=8~\text{TeV}$} with the {{ATLAS}} Detector},
  author = {ATLAS Collaboration},
  year = 2017,
  month = feb,
  journal = {The European Physical Journal C},
  volume = {77},
  number = {2},
  pages = {76--110},
  issn = {1434-6052},
  doi = {10.1140/epjc/s10052-017-4644-9},
  urldate = {2025-12-19},
  abstract = {The production of two prompt \$\$J/\textbackslash psi \$\$mesons, each with transverse momenta \$\$p\_\textbraceleft\textbackslash mathrm \textbraceleft T\textbraceright\textbraceright{$>$}8.5\$\$~GeV and rapidity \$\$\textbar y\textbar{} {$<$} 2.1\$\$, is studied using a sample of proton-proton collisions at \$\$\textbackslash sqrt\textbraceleft s\textbraceright{} = 8\$\$~TeV, corresponding to an integrated luminosity of 11.4~fb\$\$\textasciicircum\textbraceleft -1\textbraceright\$\$collected in 2012 with the ATLAS detector at the LHC. The differential cross-section, assuming unpolarised \$\$J/\textbackslash psi \$\$production, is measured as a function of the transverse momentum of the lower-\$\$p\_\textbraceleft\textbackslash mathrm \textbraceleft T\textbraceright\textbraceright\$\$\$\$J/\textbackslash psi \$\$meson, di-\$\$J/\textbackslash psi \$\$\$\$p\_\textbraceleft\textbackslash mathrm \textbraceleft T\textbraceright\textbraceright\$\$and mass, the difference in rapidity between the two \$\$J/\textbackslash psi \$\$mesons, and the azimuthal angle between the two \$\$J/\textbackslash psi \$\$mesons. The fraction of prompt pair events due to double parton scattering is determined by studying kinematic correlations between the two \$\$J/\textbackslash psi \$\$mesons. The total and double parton scattering cross-sections are compared with predictions. The effective cross-section of double parton scattering is measured to be \$\$\textbackslash sigma \_\textbraceleft\textbackslash mathrm \textbraceleft eff\textbraceright\textbraceright{} = 6.3 \textbackslash pm 1.6 \textbackslash mathrm \textbraceleft (stat)\textbraceright{} \textbackslash pm 1.0 \textbackslash mathrm \textbraceleft (syst)\textbraceright\$\$~mb.},
  langid = {english},
  file = {/Users/ericwang/Zotero/storage/ITUNU5SE/Aaboud 等 - 2017 - Measurement of the prompt J$$psi $$pair production cross-section in pp collisions at $$sqrt s =.pdf}
}

@article{ATLASSameSignWW13TeV2025,
  title = {Observation of Double Parton Scattering in Same-Sign {{W}} Boson Pair Production in {$pp$} Collisions at {$\sqrt{s}=13~\text{TeV}$} with the {{ATLAS}} Detector},
  author = {ATLAS Collaboration},
  year = 2025,
  month = nov,
  journal = {Physics Letters B},
  volume = {870},
  eprint = {2505.08313},
  primaryclass = {hep-ex},
  pages = {139892},
  issn = {03702693},
  doi = {10.1016/j.physletb.2025.139892},
  urldate = {2026-01-12},
  abstract = {This letter reports the measurement of double parton scattering in same-sign W boson pair production with the ATLAS detector. The data set used corresponds to an integrated luminosity of 140 fb\$\textasciicircum\textbraceleft -1\textbraceright\$ of proton-proton collisions at a center-of-mass energy of 13 TeV, collected during Run 2 of the Large Hadron Collider. The study is performed in final states including two same-charge leptons, electron or muon, missing transverse momentum, and up to one jet. An excess of events is observed over the expected background contributions with a significance of 8.8 standard deviations. The measured fiducial cross section times leptonic branching fraction is \$4.59 \textbackslash pm 0.64\$ fb. The measurement corresponds to a double parton scattering effective cross section of \$10.6 \textbackslash pm 1.8\$ mb.},
  archiveprefix = {arXiv},
  langid = {english},
  keywords = {BETA,DPS,High Energy Physics - Experiment,Same-sign WW WW},
  file = {/Users/ericwang/Zotero/storage/8R8Q8IAA/Collaboration - 2025 - Observation of double parton scattering in same-sign W boson pair production in pp collisions at $s.pdf}
}

